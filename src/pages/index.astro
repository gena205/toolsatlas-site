---
import ToolLayout from "../layouts/ToolLayout.astro";
import tools from "../data/tools.json";

const categories = [
  { id: "developer-tools", name: "Developer Tools", description: "JSON, Base64, hashes, encoders, and developer utilities." },
  { id: "network-tools", name: "Network Tools", description: "IP, DNS, ping, and port-related tools." },
  { id: "text-tools", name: "Text Tools", description: "Word count, case conversion, and text cleanup tools." },
  { id: "converters", name: "Converters", description: "Timestamp, bytes, and other simple conversion tools." },
  { id: "calculators", name: "Calculators", description: "Fast online calculators for common tasks." }
];

const toolsByCategory = categories.map((category) => ({
  ...category,
  tools: tools.filter((tool) => tool.category === category.id)
}));

const totalTools = tools.length;
---

<ToolLayout
  title="ToolsAtlas - Free Online Developer, Network, Text, Converter and Calculator Tools"
  description="Free online tools for developers, networking, text editing, conversions, and calculations. Simple, fast, and easy to use."
>
  <section class="card hero">
    <p class="eyebrow">Free Online Tools</p>
    <h1>Simple tools for developers, network tasks, text work, conversions, and calculations</h1>
    <p class="hero-text">
      ToolsAtlas is a growing library of practical online tools built for speed, clarity, and useful everyday workflows.
    </p>

    <div class="hero-stats">
      <div class="stat">
        <strong>{totalTools}</strong>
        <span>Tools live</span>
      </div>
      <div class="stat">
        <strong>5</strong>
        <span>Categories</span>
      </div>
      <div class="stat">
        <strong>Free</strong>
        <span>No signup</span>
      </div>
    </div>
  </section>

  <section class="card">
    <h2>Browse by category</h2>
    <div class="category-grid">
      {toolsByCategory.map((category) => (
        <div class="category-box">
          <h3>{category.name}</h3>
          <p>{category.description}</p>
          <p class="small">{category.tools.length} tools</p>
        </div>
      ))}
    </div>
  </section>

  <section class="card">
    <h2>Featured tools</h2>
    <div class="tool-grid">
      {tools.slice(0, 8).map((tool) => (
        <a class="tool-card" href={`/tools/${tool.slug}`}>
          <span class="tool-category">{tool.category}</span>
          <strong>{tool.name}</strong>
          <p>{tool.intro}</p>
        </a>
      ))}
    </div>
  </section>

  {toolsByCategory.map((category) => (
    <section class="card">
      <h2>{category.name}</h2>
      <p class="section-text">{category.description}</p>

      {category.tools.length > 0 ? (
        <ul class="tool-list">
          {category.tools.map((tool) => (
            <li>
              <a href={`/tools/${tool.slug}`}>{tool.name}</a> — {tool.description}
            </li>
          ))}
        </ul>
      ) : (
        <p>No tools in this category yet.</p>
      )}
    </section>
  ))}

  <section class="card">
    <h2>Why use ToolsAtlas?</h2>
    <ul>
      <li>Fast, simple online tools</li>
      <li>Clear pages with helpful explanations</li>
      <li>Useful for quick daily tasks</li>
      <li>Built to keep growing over time</li>
    </ul>
  </section>
</ToolLayout>

<style>
  .hero {
    padding: 28px;
  }

  .eyebrow {
    color: var(--accent);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 12px;
    margin-bottom: 10px;
  }

  .hero h1 {
    font-size: 38px;
    line-height: 1.15;
    margin-bottom: 14px;
  }

  .hero-text {
    color: var(--muted);
    font-size: 18px;
    max-width: 760px;
  }

  .hero-stats {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
    margin-top: 24px;
  }

  .stat {
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 16px;
    background: #0f172a;
  }

  .stat strong {
    display: block;
    font-size: 24px;
    margin-bottom: 4px;
  }

  .stat span {
    color: var(--muted);
    font-size: 14px;
  }

  .category-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
  }

  .category-box {
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 18px;
    background: #0f172a;
  }

  .category-box p {
    margin-bottom: 0;
  }

  .tool-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
  }

  .tool-card {
    display: block;
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 18px;
    background: #0f172a;
    color: var(--text);
  }

  .tool-card strong {
    display: block;
    margin: 8px 0;
    font-size: 18px;
  }

  .tool-card p {
    margin: 0;
    color: var(--muted);
  }

  .tool-category {
    display: inline-block;
    font-size: 12px;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .tool-list li + li {
    margin-top: 10px;
  }

  .section-text {
    color: var(--muted);
    margin-bottom: 16px;
  }

  @media (max-width: 800px) {
    .hero h1 {
      font-size: 30px;
    }

    .hero-stats,
    .category-grid,
    .tool-grid {
      grid-template-columns: 1fr;
    }
  }
</style>