---
import ToolLayout from "../layouts/ToolLayout.astro";
import tools from "../data/tools.json";

type ToolItem = {
  id: string;
  name: string;
  slug: string;
  category: string;
  intro: string;
  description: string;
};

const allTools = tools as ToolItem[];

const categories = [
  {
    id: "developer-tools",
    name: "Developer Tools",
    description: "JSON, Base64, hashes, encoders, decoders, and developer utilities."
  },
  {
    id: "network-tools",
    name: "Network Tools",
    description: "IP, DNS, ping, port, and other networking tools."
  },
  {
    id: "text-tools",
    name: "Text Tools",
    description: "Word count, line count, text cleanup, text converters, and other text tools."
  },
  {
    id: "converters",
    name: "Converters",
    description: "Timestamp, bytes, and other simple online converters."
  },
  {
    id: "calculators",
    name: "Calculators",
    description: "Percentage, age, and other useful calculators."
  }
];

const toolsByCategory = categories.map((category) => ({
  ...category,
  tools: allTools.filter((tool) => tool.category === category.id)
}));

const totalTools = allTools.length;
---

<ToolLayout
  title="ToolsAtlas - Free Online Developer, Network, Text, Converter and Calculator Tools"
  description="Free online tools for developers, networking, text editing, conversions, and calculations. Simple, fast, and easy to use."
>
  <section class="card hero">
    <p class="eyebrow">Free Online Tools</p>
    <h1>Simple online tools for daily work</h1>
    <p class="hero-text">
      ToolsAtlas is a growing collection of useful browser-based tools for developers, network tasks, text editing, conversions, and calculations.
    </p>

    <div class="hero-stats">
      <div class="stat">
        <strong>{totalTools}</strong>
        <span>Tools</span>
      </div>
      <div class="stat">
        <strong>5</strong>
        <span>Categories</span>
      </div>
      <div class="stat">
        <strong>Free</strong>
        <span>Online use</span>
      </div>
    </div>

        <p class="hero-link">
      <a href="/tools/">Browse all tools</a>
    </p>
  </section>

  <section class="card">
    <h2>Browse tool categories</h2>
    <div class="category-grid">
      {toolsByCategory.map((category) => (
        <a class="category-card" href={`/tools/category/${category.id}`}>
          <strong>{category.name}</strong>
          <p>{category.description}</p>
          <span>{category.tools.length} tools</span>
        </a>
      ))}
    </div>
  </section>

  <section class="card">
    <h2>Featured tools</h2>
    <div class="tool-grid">
      {allTools.slice(0, 8).map((tool) => (
        <a class="tool-card" href={`/tools/${tool.slug}`}>
          <span class="tool-category">{tool.category}</span>
          <strong>{tool.name}</strong>
          <p>{tool.intro}</p>
        </a>
      ))}
    </div>
  </section>

  {toolsByCategory.map((category) => (
    <section class="card">
      <h2>{category.name}</h2>
      <p class="section-text">{category.description}</p>
      <p class="section-link">
        <a href={`/tools/category/${category.id}`}>View all {category.name.toLowerCase()}</a>
      </p>

      <ul class="tool-list">
        {category.tools.slice(0, 6).map((tool) => (
          <li>
            <a href={`/tools/${tool.slug}`}>{tool.name}</a> — {tool.description}
          </li>
        ))}
      </ul>
    </section>
  ))}
</ToolLayout>

<style>
  .eyebrow {
    color: var(--accent);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 12px;
    margin-bottom: 10px;
  }

  .hero h1 {
    font-size: 38px;
    line-height: 1.15;
    margin-bottom: 14px;
  }

  .hero-text {
    color: var(--muted);
    font-size: 18px;
    max-width: 760px;
  }

    .hero-link {
    margin-top: 18px;
  }

  .hero-link a {
    color: var(--accent);
    font-weight: 700;
  }

  .hero-stats {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
    margin-top: 24px;
  }


  .stat {
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 16px;
    background: #0f172a;
  }

  .stat strong {
    display: block;
    font-size: 24px;
    margin-bottom: 4px;
  }

  .stat span {
    color: var(--muted);
    font-size: 14px;
  }

  .category-grid,
  .tool-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
  }

  .category-card,
  .tool-card {
    display: block;
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 18px;
    background: #0f172a;
    color: var(--text);
  }

  .category-card strong,
  .tool-card strong {
    display: block;
    margin-bottom: 8px;
    font-size: 18px;
  }

  .category-card p,
  .tool-card p {
    margin: 0 0 10px 0;
    color: var(--muted);
  }

  .category-card span {
    color: var(--accent);
    font-size: 14px;
    font-weight: 700;
  }

  .tool-category {
    display: inline-block;
    font-size: 12px;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 8px;
  }

  .section-text {
    color: var(--muted);
    margin-bottom: 10px;
  }

  .section-link {
    margin-bottom: 16px;
  }

  .tool-list li + li {
    margin-top: 10px;
  }

  @media (max-width: 800px) {
    .hero h1 {
      font-size: 30px;
    }

    .hero-stats,
    .category-grid,
    .tool-grid {
      grid-template-columns: 1fr;
    }

    .hero-text {
      font-size: 16px;
    }
  }
</style>