---
import ToolLayout from "../layouts/ToolLayout.astro";
import tools from "../data/tools.json";
---

<ToolLayout title="ToolsAtlas - Free Online Tools" description="Free online developer, network, text, converter and calculator tools.">
  <section class="card">
    <h1>Free Online Tools</h1>
    <p>ToolsAtlas is a growing collection of simple and useful online tools.</p>
  </section>

  <section class="card">
    <h2>Featured Tools</h2>
    <ul>
      {tools.map((tool) => (
        <li>
          <a href={`/tools/${tool.slug}`}>{tool.name}</a> — {tool.description}
        </li>
      ))}
    </ul>
  </section>
</ToolLayout>