---
import ToolLayout from "../../layouts/ToolLayout.astro";
import tools from "../../data/tools.json";

type ToolItem = {
  id: string;
  name: string;
  slug: string;
  category: string;
  intro: string;
  description: string;
};

const allTools = tools as ToolItem[];

const categories = [
  {
    id: "developer-tools",
    name: "Developer Tools",
    description: "JSON, Base64, hashes, encoders, decoders, and developer utilities."
  },
  {
    id: "network-tools",
    name: "Network Tools",
    description: "IP, DNS, ping, port, and other networking tools."
  },
  {
    id: "text-tools",
    name: "Text Tools",
    description: "Word count, line count, text cleanup, text converters, and other text tools."
  },
  {
    id: "converters",
    name: "Converters",
    description: "Timestamp, bytes, and other simple online converters."
  },
  {
    id: "calculators",
    name: "Calculators",
    description: "Percentage, age, and other useful calculators."
  }
];

const toolsByCategory = categories.map((category) => ({
  ...category,
  tools: allTools.filter((tool) => tool.category === category.id)
}));
---

<ToolLayout
  title="All Tools - ToolsAtlas"
  description="Browse all online tools on ToolsAtlas by category: developer tools, network tools, text tools, converters, and calculators."
>
  <section class="card hero">
    <p class="eyebrow">All Tools</p>
    <h1>Browse all ToolsAtlas tools</h1>
    <p class="hero-text">
      Explore all available tools by category. Use this page as the main catalog for developer tools, text tools, network tools, converters, and calculators.
    </p>
    <p class="small">{allTools.length} tools available</p>
  </section>

  {toolsByCategory.map((category) => (
    <section class="card">
      <h2>{category.name}</h2>
      <p class="section-text">{category.description}</p>
      <p class="section-link">
        <a href={`/tools/category/${category.id}`}>Open {category.name.toLowerCase()}</a>
      </p>

      <div class="tool-grid">
        {category.tools.map((tool) => (
          <a class="tool-card" href={`/tools/${tool.slug}`}>
            <strong>{tool.name}</strong>
            <p>{tool.intro}</p>
          </a>
        ))}
      </div>
    </section>
  ))}
</ToolLayout>

<style>
  .eyebrow {
    color: var(--accent);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 12px;
    margin-bottom: 10px;
  }

  .hero-text {
    color: var(--muted);
    font-size: 18px;
    max-width: 760px;
  }

  .section-text {
    color: var(--muted);
    margin-bottom: 10px;
  }

  .section-link {
    margin-bottom: 16px;
  }

  .tool-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
  }

  .tool-card {
    display: block;
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 18px;
    background: #0f172a;
    color: var(--text);
  }

  .tool-card strong {
    display: block;
    margin-bottom: 8px;
    font-size: 18px;
  }

  .tool-card p {
    margin: 0;
    color: var(--muted);
  }

  @media (max-width: 800px) {
    .tool-grid {
      grid-template-columns: 1fr;
    }

    .hero-text {
      font-size: 16px;
    }
  }
</style>