function decodeBase64UrlToText(value: string): string {
  const normalized = value.replace(/-/g, "+").replace(/_/g, "/");
  const padded = normalized + "=".repeat((4 - (normalized.length % 4 || 4)) % 4);

  try {
    const decoded = atob(padded);
    return decodeURIComponent(
      Array.from(decoded)
        .map((char: string) => `%${char.charCodeAt(0).toString(16).padStart(2, "0")}`)
        .join("")
    );
  } catch {
    return decodedURIComponentFallback(padded);
  }
}

function decodedURIComponentFallback(base64Value: string): string {
  try {
    return atob(base64Value);
  } catch {
    return "";
  }
}

