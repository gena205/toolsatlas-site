  const d = max - min;

  if (d !== 0) {
    s = d / (1 - Math.abs(2 * l - 1));

    switch (max) {
      case r:
        h = 60 * (((g - b) / d) % 6);
        break;
      case g:
        h = 60 * ((b - r) / d + 2);
        break;
      default:
        h = 60 * ((r - g) / d + 4);
        break;
    }
  }

  if (h < 0) h += 360;

  output.value = `hsl(${Math.round(h)}, ${Math.round(s * 100)}%, ${Math.round(l * 100)}%)`;
  return;
}

if (slug === "hsl-to-rgb") {
  const text = input.value.trim();

  if (!text) {
    output.value = "Enter HSL values like 11, 100%, 60%.";
    return;
  }

  const matches = text.match(/-?\d+(?:\.\d+)?/g)?.map((value: string) => Number(value)) || [];

  if (matches.length < 3) {
    output.value = "Enter hue, saturation, and lightness values.";
    return;
  }

  let [h, s, l] = matches;
  h = ((h % 360) + 360) % 360;
  s = Math.max(0, Math.min(100, s)) / 100;
  l = Math.max(0, Math.min(100, l)) / 100;

  const c = (1 - Math.abs(2 * l - 1)) * s;
  const x = c * (1 - Math.abs((h / 60) % 2 - 1));
  const m = l - c / 2;

  let r1 = 0;
  let g1 = 0;
  let b1 = 0;

  if (h < 60) {
    r1 = c; g1 = x; b1 = 0;
  } else if (h < 120) {
    r1 = x; g1 = c; b1 = 0;
  } else if (h < 180) {
    r1 = 0; g1 = c; b1 = x;
  } else if (h < 240) {
    r1 = 0; g1 = x; b1 = c;
  } else if (h < 300) {
    r1 = x; g1 = 0; b1 = c;
  } else {
    r1 = c; g1 = 0; b1 = x;
  }

  const r = Math.round((r1 + m) * 255);
  const g = Math.round((g1 + m) * 255);
  const b = Math.round((b1 + m) * 255);

  output.value = `rgb(${r}, ${g}, ${b})`;
  return;
}
if (slug === "css-minifier") {
  const text = input.value;

  if (!text.trim()) {
    output.value = "Enter CSS.";
    return;
  }

  let result = text;

  result = result.replace(/\/\*[\s\S]*?\*\//g, "");
  result = result.replace(/\s+/g, " ");
  result = result.replace(/\s*([{}:;,>])\s*/g, "$1");
  result = result.replace(/;}/g, "}");
  result = result.trim();

  output.value = result;
  return;
}

if (slug === "css-beautifier") {
  const text = input.value.trim();

  if (!text) {
    output.value = "Enter CSS.";
    return;
  }

  let result = text
    .replace(/\s*{\s*/g, " {\n")
    .replace(/\s*}\s*/g, "\n}\n")
    .replace(/\s*;\s*/g, ";\n")
    .replace(/\s*,\s*/g, ", ")
    .replace(/\n{3,}/g, "\n\n");

  const lines = result.split("\n");
  let indent = 0;
  const formatted: string[] = [];

  for (let rawLine of lines) {
    const line = rawLine.trim();
    if (!line) continue;

    if (line.startsWith("}")) {
      indent = Math.max(0, indent - 1);
    }

    formatted.push(`${"  ".repeat(indent)}${line}`);

    if (line.endsWith("{")) {
      indent += 1;
    }
  }

  output.value = formatted.join("\n");
  return;
}

if (slug === "regex-generator-simple") {
  const text = input.value.trim();

  if (!text) {
    output.value = "Enter rules as JSON or key=value lines.";
    return;
  }

  const config: Record<string, string> = {};

  try {
    const parsed = JSON.parse(text);

    if (typeof parsed === "object" && parsed !== null && !Array.isArray(parsed)) {
      for (const [key, value] of Object.entries(parsed as Record<string, unknown>)) {
        config[key] = String(value);
      }
    } else {
      output.value = "Use a JSON object or key=value lines.";
      return;
    }
  } catch {
    const lines = text.split(/\r?\n/).map((line: string) => line.trim()).filter(Boolean);

    for (const line of lines) {
      const [rawKey, ...rest] = line.split("=");
      if (!rawKey || rest.length === 0) continue;
      config[rawKey.trim()] = rest.join("=").trim();
    }
  }

  const mode = (config.mode || "").trim();
  const value = config.value || "";
  const length = Number(config.length || "");

  const escapeRegex = (str: string): string =>
    str.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");

  let pattern = "";

  if (mode === "digits") {
    pattern = "^\\d+$";
  } else if (mode === "letters") {
    pattern = "^[A-Za-z]+$";
  } else if (mode === "alphanumeric") {
    pattern = "^[A-Za-z0-9]+$";
  } else if (mode === "exact") {
    if (!value) {
      output.value = "Mode exact requires a value.";
      return;
    }
    pattern = `^${escapeRegex(value)}$`;
  } else if (mode === "contains") {
    if (!value) {
      output.value = "Mode contains requires a value.";
      return;
    }
    pattern = escapeRegex(value);
  } else if (mode === "startsWith") {
    if (!value) {
      output.value = "Mode startsWith requires a value.";
      return;
    }
    pattern = `^${escapeRegex(value)}`;
  } else if (mode === "endsWith") {
    if (!value) {
      output.value = "Mode endsWith requires a value.";
      return;
    }
    pattern = `${escapeRegex(value)}$`;
  } else if (mode === "customLengthDigits") {
    if (!Number.isInteger(length) || length <= 0) {
      output.value = "Mode customLengthDigits requires a positive integer length.";
      return;
    }
    pattern = `^\\d{${length}}$`;
  } else {
    output.value =
      'Use a supported mode: exact, contains, startsWith, endsWith, digits, letters, alphanumeric, or customLengthDigits.';
    return;
  }

  output.value = JSON.stringify(
    {
      mode,
      pattern: `/${pattern}/`
    },
    null,
    2
  );
  return;
}
