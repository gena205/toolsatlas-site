---
import ToolLayout from "../../layouts/ToolLayout.astro";
import tools from "../../data/tools.json";

export async function getStaticPaths() {
  return tools.map((tool) => ({
    params: { slug: tool.slug },
    props: { tool }
  }));
}

const { tool } = Astro.props;
const relatedTools = tools.filter((item) => tool.related?.includes(item.id));
---

<ToolLayout title={`${tool.name} - ToolsAtlas`} description={tool.description}>
  <section class="card">
    <p class="small">{tool.category}</p>
    <h1>{tool.name}</h1>
    <p>{tool.intro}</p>
  </section>

  <section class="card">
    <h2>Tool</h2>
    <p>{tool.description}</p>
    <textarea rows="8" placeholder={`Use the ${tool.name} here...`}></textarea>
    <button>Run Tool</button>
  </section>

  <section class="card">
    <h2>How to use</h2>
    <ul>
      <li>Paste your input into the tool.</li>
      <li>Click the button to process the input.</li>
      <li>Copy the result.</li>
    </ul>
  </section>

  <section class="card">
    <h2>FAQ</h2>
    {tool.faq?.map((item) => (
      <>
        <h3>{item.q}</h3>
        <p>{item.a}</p>
      </>
    ))}
  </section>

  <section class="card">
    <h2>Related tools</h2>
    <ul>
      {relatedTools.map((item) => (
        <li><a href={`/tools/${item.slug}`}>{item.name}</a></li>
      ))}
    </ul>
  </section>
</ToolLayout>