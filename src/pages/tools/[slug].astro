---
import ToolLayout from "../../layouts/ToolLayout.astro";
import tools from "../../data/tools.json";

export async function getStaticPaths() {
  return tools.map((tool) => ({
    params: { slug: tool.slug },
    props: { tool }
  }));
}

const { tool } = Astro.props;
---

<ToolLayout title={`${tool.name} - ToolsAtlas`} description={tool.description}>
  <section class="card">
    <p class="small">{tool.category}</p>
    <h1>{tool.name}</h1>
    <p>{tool.description}</p>
  </section>

  <section class="card">
    <h2>Tool</h2>
    <p>This is the first version of the <strong>{tool.name}</strong> page.</p>
    <textarea rows="8" placeholder={`Use the ${tool.name} here...`}></textarea>
    <button>Run Tool</button>
  </section>

  <section class="card">
    <h2>How to use</h2>
    <ul>
      <li>Paste your input into the text area.</li>
      <li>Click the button.</li>
      <li>Copy the result.</li>
    </ul>
  </section>

  <section class="card">
    <h2>FAQ</h2>
    <h3>What does {tool.name} do?</h3>
    <p>{tool.description}</p>

    <h3>Is this tool free?</h3>
    <p>Yes, this tool is free to use online.</p>
  </section>
</ToolLayout>