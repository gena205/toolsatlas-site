  }

  const lines = text.replace(/\r\n/g, "\n").split("\n").filter((line: string) => line.trim() !== "");

  if (lines.length < 2) {
    output.value = "Enter CSV with a header row and at least one data row.";
    return;
  }

  const parseCsvLine = (line: string): string[] => {
    const result: string[] = [];
    let current = "";
    let inQuotes = false;

    for (let i = 0; i < line.length; i++) {
      const char = line[i];
      const next = line[i + 1];

      if (char === '"' && inQuotes && next === '"') {
        current += '"';
        i++;
        continue;
      }

      if (char === '"') {
        inQuotes = !inQuotes;
        continue;
      }

      if (char === "," && !inQuotes) {
        result.push(current);
        current = "";
        continue;
      }

      current += char;
    }

    result.push(current);
    return result.map((item: string) => item.trim());
  };

  const headers = parseCsvLine(lines[0]);

  if (headers.some((header: string) => !header)) {
    output.value = "Invalid CSV header.";
    return;
  }

  const escapeXml = (value: string): string =>
    value
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&apos;");

  const items = lines.slice(1).map((line: string) => {
    const cols = parseCsvLine(line);

    if (cols.length !== headers.length) {
      throw new Error("Invalid CSV row.");
    }

    const fields = headers.map((header: string, index: number) =>
      `<${header}>${escapeXml(cols[index] ?? "")}</${header}>`
    ).join("");

    return `<item>${fields}</item>`;
