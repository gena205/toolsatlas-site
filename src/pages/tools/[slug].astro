---
import ToolLayout from "../../layouts/ToolLayout.astro";
import tools from "../../data/tools.json";
import ToolClusterNav from "../../components/ToolClusterNav.astro";

type ToolFaqItem = {
  q: string;
  a: string;
};

type ToolExampleItem = {
  input: string;
  output: string;
  explanation?: string;
};

type ToolCommonErrorItem = {
  issue: string;
  fix: string;
};

type ToolItem = {
  id: string;
  name: string;
  slug: string;
  category: string;
  intro: string;
  description: string;
  keywords?: string[];
  faq?: ToolFaqItem[];
  related?: string[];
  whyUse?: string[];
  howToUse?: string[];
  examples?: ToolExampleItem[];
  useCases?: string[];
  commonErrors?: ToolCommonErrorItem[];
};

const allTools = tools as ToolItem[];

export async function getStaticPaths() {
  return (tools as ToolItem[]).map((tool) => ({
    params: { slug: tool.slug },
    props: { tool }
  }));
}

const { tool } = Astro.props as { tool: ToolItem };
const relatedTools = allTools.filter((item) => tool.related?.includes(item.id));

function formatCategoryLabel(category: string): string {
  return category
    .split("-")
    .map((part: string) => part.charAt(0).toUpperCase() + part.slice(1))
    .join(" ");
}
---

<ToolLayout title={`${tool.name} Online Free Tool – Fast & Easy | ToolsAtlas`} description={`${tool.description} Free online tool. No installation required. Fast and easy to use.`}>
  <section class="card tool-hero">
    <p class="category-pill">{formatCategoryLabel(tool.category)}</p>
    <h1>{tool.name}</h1>
    <p class="lead">{tool.intro}</p>
  </section>

  <section class="card tool-panel">
    <ToolClusterNav slug={tool.slug} current="main" />
    <div class="tool-panel-header">
      <div>
        <h2>Tool</h2>
        <p class="panel-text">{tool.description}</p>
      </div>
    </div>

    <div class="tool-grid">
      <div class="tool-column">
        <label for="tool-input" class="field-label">
          {tool.slug === "my-ip-address" ? "Info" : "Input"}
        </label>

        <textarea
          id="tool-input"
          class="tool-textarea"
          rows="12"
          placeholder={tool.slug === "my-ip-address"
            ? ""
            : `Paste or type your input for ${tool.name} here...`}
          style={tool.slug === "my-ip-address" ? "display:none;" : ""}
        ></textarea>

        {tool.slug === "my-ip-address" && (
          <div
            class="tool-textarea output-textarea"
            style="display:flex;align-items:center;justify-content:center;"
          >
            No input required for this tool.
          </div>
        )}

        <div class="button-row">
  <button type="button" id="run-tool-btn" class="primary-button">Run Tool</button>
  <button type="button" id="copy-input-btn" class="secondary-button">Copy Input</button>
  <button type="button" id="clear-btn" class="secondary-button">Clear</button>
</div>
      </div>

      <div class="tool-column">
        <label for="tool-output" class="field-label">Output</label>
        <textarea
          id="tool-output"
          class="tool-textarea output-textarea"
          rows="12"
          placeholder="The result will appear here..."
          readonly
        ></textarea>

        <div class="button-row">
  <button type="button" id="copy-result-btn" class="secondary-button">Copy Result</button>
  <button type="button" id="download-btn" class="secondary-button">Download</button>
</div>
    </div>
  </section>

    <section class="card">
    <h2>About this tool</h2>
    <p>{tool.description}</p>
    <p>Use {tool.name.toLowerCase()} when you need a fast browser-based result without extra setup. It works well for quick checks, one-off tasks, and routine formatting or calculation work.</p>
  </section>

  {tool.slug === "text-diff-checker" && (
  <section class="card">
    <h2>When to use Text Diff Checker</h2>
    <ul>
      <li>When you need to compare two drafts before publishing or submitting</li>
      <li>When checking whether copied text changed during editing or transfer</li>
      <li>When reviewing code, config, or notes for small differences</li>
      <li>When comparing titles, descriptions, or short content variations</li>
      <li>When you want to confirm that two text blocks are exactly the same</li>
    </ul>
  </section>
)}

{tool.slug === "website-security-scanner" && (
  <section class="card">
    <h2>When to use Website Security Scanner</h2>
    <ul>
      <li>When reviewing a website before launch or handoff</li>
      <li>When checking whether HTTPS and redirects are configured correctly</li>
      <li>When running a quick client audit before deeper investigation</li>
      <li>When checking visible security signals and technical website basics in one place</li>
      <li>When you want a fast first-pass scan before using more advanced tools</li>
    </ul>
  </section>
)}

{tool.slug === "website-security-scanner" && (
  <section class="card">
    <h2>Website Security Scanner vs related tools</h2>

    <h3>Website Security Scanner vs Header Checker</h3>
    <p>
      A header checker focuses mainly on HTTP response headers.
      Website Security Scanner gives a broader first-pass view by combining HTTPS, redirects, headers, robots.txt, and sitemap checks.
      If you want a wider launch or audit snapshot, the scanner is the better first step.
    </p>

    <h3>Website Security Scanner vs SSL Checker</h3>
    <p>
      SSL Checker is more focused on certificate and HTTPS details.
      Website Security Scanner looks at broader visible website signals around security and technical setup.
      If your question is specifically about certificate quality, use the SSL tool.
      If you want a wider website-level overview, start with this scanner.
    </p>
  </section>
)}

{tool.slug === "website-security-scanner" && (
  <section class="card">
