    }

    totalQualityPoints += gradePoints * credits;
    totalCredits += credits;
  }

  const gpa = totalQualityPoints / totalCredits;

  output.value =
    `Courses: ${lines.length}\n` +
    `Total credits: ${totalCredits.toFixed(2)}\n` +
    `GPA: ${gpa.toFixed(2)}`;
