if (slug === "ip-range-calculator") {
  const text = input.value.trim();

  if (!text) {
    output.value = "Enter IPv4 CIDR like: 192.168.1.10/24";
    return;
  }

  const match = text.match(/^(\d{1,3}(?:\.\d{1,3}){3})\/(\d{1,2})$/);

  if (!match) {
    output.value = "Invalid format. Use IPv4 CIDR like: 192.168.1.10/24";
    return;
  }

  const ip = match[1];
  const prefix = Number(match[2]);
  const octets = ip.split(".").map((part) => Number(part));

  if (
    octets.length !== 4 ||
    octets.some((n) => !Number.isInteger(n) || n < 0 || n > 255) ||
    !Number.isInteger(prefix) ||
    prefix < 0 ||
    prefix > 32
  ) {
    output.value = "Invalid IPv4 or CIDR prefix. Use octets 0-255 and prefix 0-32.";
    return;
  }

  const ipToInt = (parts: number[]): number =>
    (((parts[0] << 24) >>> 0) +
      ((parts[1] << 16) >>> 0) +
      ((parts[2] << 8) >>> 0) +
      (parts[3] >>> 0)) >>> 0;

  const intToIp = (num: number): string =>
    [
      (num >>> 24) & 255,
      (num >>> 16) & 255,
      (num >>> 8) & 255,
      num & 255
    ].join(".");

  const ipInt = ipToInt(octets);
  const mask = prefix === 0 ? 0 : ((0xffffffff << (32 - prefix)) >>> 0);
  const network = (ipInt & mask) >>> 0;
  const broadcast = (network | (~mask >>> 0)) >>> 0;
  const totalAddresses = Math.pow(2, 32 - prefix);

  let firstUsable = network;
  let lastUsable = broadcast;
  let usableHosts = totalAddresses;

  if (prefix <= 30) {
    firstUsable = network + 1;
    lastUsable = broadcast - 1;
    usableHosts = totalAddresses - 2;
  } else if (prefix === 31) {
    usableHosts = 2;
  } else if (prefix === 32) {
    usableHosts = 1;
  }

  output.value =
    `Network: ${intToIp(network)}\n` +
    `First Usable: ${intToIp(firstUsable >>> 0)}\n` +
    `Last Usable: ${intToIp(lastUsable >>> 0)}\n` +
    `Broadcast: ${intToIp(broadcast)}\n` +
    `Total Addresses: ${totalAddresses}\n` +
    `Usable Hosts: ${usableHosts}`;

  return;
}
if (slug === "json-to-yaml") {
  const text = input.value.trim();

  if (!text) {
    output.value = 'Enter valid JSON.\nExample:\n{"name":"John","age":30}';
    return;
  }

  const isPlainObject = (value: unknown): value is Record<string, unknown> =>
    typeof value === "object" && value !== null && !Array.isArray(value);

  const formatScalar = (value: unknown): string => {
    if (value === null) return "null";
    if (typeof value === "string") {
      if (value === "" || /[:#\-\n\r\t]/.test(value) || /^\s|\s$/.test(value)) {
        return JSON.stringify(value);
      }
      return value;
    }
    if (typeof value === "number" || typeof value === "boolean") {
      return String(value);
    }
    return JSON.stringify(value);
  };

  const toYaml = (value: unknown, indent = 0): string => {
    const space = "  ".repeat(indent);

    if (Array.isArray(value)) {
      if (value.length === 0) {
        return `${space}[]`;
      }

      return value
        .map((item: unknown) => {
          if (Array.isArray(item) || isPlainObject(item)) {
            const nested = toYaml(item, indent + 1);
            const nestedLines = nested.split("\n");
            return `${space}- ${nestedLines[0].trimStart()}\n${nestedLines.slice(1).join("\n")}`;
          }
          return `${space}- ${formatScalar(item)}`;
        })
        .join("\n");
    }

    if (isPlainObject(value)) {
      const entries = Object.entries(value);

      if (entries.length === 0) {
        return `${space}{}`;
      }

      return entries
        .map(([key, val]) => {
          if (Array.isArray(val) || isPlainObject(val)) {
            return `${space}${key}:\n${toYaml(val, indent + 1)}`;
          }
          return `${space}${key}: ${formatScalar(val)}`;
        })
        .join("\n");
    }

    return `${space}${formatScalar(value)}`;
  };

  try {
    const data = JSON.parse(text);
