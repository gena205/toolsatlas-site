        output.value = "Unsupported unit. Use words, sentences, or paragraphs.";
        return;
      }
            if (slug === "api-request-body-formatter") {
        const text = input.value.trim();

        if (!text) {
          output.value = "Enter a request body to format.";
          return;
        }

        const assignNestedValue = (
          target: Record<string, unknown>,
          path: string[],
          value: unknown
        ): void => {
          let current: Record<string, unknown> = target;

          path.forEach((part: string, index: number) => {
            const isLast = index === path.length - 1;

            if (isLast) {
              if (Object.prototype.hasOwnProperty.call(current, part)) {
                const existing = current[part];
                current[part] = Array.isArray(existing) ? [...existing, value] : [existing, value];
              } else {
                current[part] = value;
              }

              return;
            }

            if (
              !Object.prototype.hasOwnProperty.call(current, part) ||
              typeof current[part] !== "object" ||
              current[part] === null ||
              Array.isArray(current[part])
            ) {
              current[part] = {};
            }

            current = current[part] as Record<string, unknown>;
          });
        };

        const parseScalar = (value: string): unknown => {
          const trimmed = value.trim();

          if (trimmed === "") {
            return "";
          }

          if (/^(true|false)$/i.test(trimmed)) {
            return trimmed.toLowerCase() === "true";
          }

          if (/^null$/i.test(trimmed)) {
            return null;
          }

          if (/^-?\d+(\.\d+)?$/.test(trimmed)) {
            return Number(trimmed);
          }

          if (
            (trimmed.startsWith("{") && trimmed.endsWith("}")) ||
            (trimmed.startsWith("[") && trimmed.endsWith("]"))
          ) {
            try {
              return JSON.parse(trimmed);
            } catch {
            }
          }

          return trimmed;
        };

        try {
          const parsed = JSON.parse(text);
          output.value = JSON.stringify(parsed, null, 2);
          return;
        } catch {
        }

        const normalized = text.replace(/\r\n/g, "\n");

        if (/^[^=\n&]+=[^]*$/.test(normalized) && (normalized.includes("&") || !normalized.includes("\n"))) {
          const params = new URLSearchParams(normalized);
          const result: Record<string, unknown> = {};

          for (const [key, value] of params.entries()) {
            assignNestedValue(
              result,
              key.split(".").map((part: string) => part.trim()).filter(Boolean),
              parseScalar(value)
            );
          }

          output.value = JSON.stringify(result, null, 2);
          return;
        }

        const lines = normalized
          .split("\n")
          .map((line: string) => line.trim())
          .filter((line: string) => line.length > 0);

        if (lines.every((line: string) => line.includes("="))) {
          const result: Record<string, unknown> = {};

          for (const line of lines) {
            const separatorIndex = line.indexOf("=");

            if (separatorIndex === -1) {
              output.value = `Invalid line: ${line}`;
              return;
            }

            const key = line.slice(0, separatorIndex).trim();
            const value = line.slice(separatorIndex + 1).trim();

            if (!key) {
              output.value = `Invalid line: ${line}`;
              return;
            }

            assignNestedValue(
              result,
              key.split(".").map((part: string) => part.trim()).filter(Boolean),
              parseScalar(value)
            );
          }

          output.value = JSON.stringify(result, null, 2);
          return;
        }

        output.value = normalized
          .split("\n")
          .map((line: string) => line.trimEnd())
          .join("\n")
          .trim();

        return;
      }

      if (slug === "json-diff-checker") {
        const text = input.value.trim();

        if (!text) {
          output.value = "Enter two JSON values to compare.";
          return;
        }

        let leftRaw = "";
        let rightRaw = "";

        try {
          const parsed = JSON.parse(text);

          if (typeof parsed === "object" && parsed !== null && !Array.isArray(parsed)) {
            leftRaw = JSON.stringify((parsed as Record<string, unknown>).left ?? null);
            rightRaw = JSON.stringify((parsed as Record<string, unknown>).right ?? null);
          } else {
            output.value = "JSON input must be an object with left and right fields.";
            return;
          }
        } catch {
          const parts = text.split(/\n---+\n/);

          if (parts.length !== 2) {
            output.value = 'Use JSON with "left" and "right", or separate the two JSON blocks with ---';
            return;
          }

          leftRaw = parts[0].trim();
          rightRaw = parts[1].trim();
        }

        let leftValue: unknown;
        let rightValue: unknown;

        try {
          leftValue = JSON.parse(leftRaw);
          rightValue = JSON.parse(rightRaw);
        } catch {
          output.value = "Invalid JSON input.";
          return;
        }

        const diffs: Array<Record<string, unknown>> = [];

        const getType = (value: unknown): string => {
          if (Array.isArray(value)) {
            return "array";
          }

          if (value === null) {
            return "null";
          }

          return typeof value;
        };

        const compare = (left: unknown, right: unknown, path: string): void => {
          const leftType = getType(left);
          const rightType = getType(right);

          if (leftType !== rightType) {
            diffs.push({
              type: "type-changed",
              path: path || "$",
              leftType,
              rightType,
              left,
              right
            });
            return;
          }

          if (Array.isArray(left) && Array.isArray(right)) {
            const maxLength = Math.max(left.length, right.length);

            for (let index = 0; index < maxLength; index++) {
              const nextPath = `${path || "$"}[${index}]`;

              if (index >= left.length) {
                diffs.push({
                  type: "added",
                  path: nextPath,
                  right: right[index]
                });
                continue;
              }

              if (index >= right.length) {
                diffs.push({
                  type: "removed",
                  path: nextPath,
                  left: left[index]
                });
                continue;
              }

              compare(left[index], right[index], nextPath);
            }

            return;
          }

          if (
            typeof left === "object" &&
            left !== null &&
            typeof right === "object" &&
            right !== null
          ) {
            const keys = Array.from(
              new Set([
                ...Object.keys(left as Record<string, unknown>),
                ...Object.keys(right as Record<string, unknown>)
              ])
            ).sort();

            for (const key of keys) {
              const nextPath = path ? `${path}.${key}` : `$.${key}`;
              const leftObject = left as Record<string, unknown>;
              const rightObject = right as Record<string, unknown>;

              if (!Object.prototype.hasOwnProperty.call(leftObject, key)) {
                diffs.push({
                  type: "added",
                  path: nextPath,
                  right: rightObject[key]
                });
                continue;
              }

              if (!Object.prototype.hasOwnProperty.call(rightObject, key)) {
                diffs.push({
                  type: "removed",
                  path: nextPath,
                  left: leftObject[key]
                });
                continue;
              }

              compare(leftObject[key], rightObject[key], nextPath);
            }

            return;
          }

          if (left !== right) {
            diffs.push({
              type: "changed",
              path: path || "$",
              left,
              right
            });
          }
        };

        compare(leftValue, rightValue, "$");

        output.value = JSON.stringify(
          {
            equal: diffs.length === 0,
            diffCount: diffs.length,
            diffs
          },
          null,
          2
        );

        return;
      }

      if (slug === "text-diff-checker") {
        const text = input.value.trim();

        if (!text) {
          output.value = "Enter two text blocks to compare.";
          return;
        }

        let leftText = "";
        let rightText = "";

        try {
          const parsed = JSON.parse(text);

          if (typeof parsed === "object" && parsed !== null && !Array.isArray(parsed)) {
            leftText = String((parsed as Record<string, unknown>).left ?? "");
            rightText = String((parsed as Record<string, unknown>).right ?? "");
          } else {
            output.value = "JSON input must be an object with left and right fields.";
            return;
          }
        } catch {
          const parts = text.split(/\n---+\n/);

          if (parts.length !== 2) {
            output.value = 'Use JSON with "left" and "right", or separate the two text blocks with ---';
            return;
          }

          leftText = parts[0];
          rightText = parts[1];
        }

        const leftLines = leftText.replace(/\r\n/g, "\n").split("\n");
        const rightLines = rightText.replace(/\r\n/g, "\n").split("\n");
        const maxLength = Math.max(leftLines.length, rightLines.length);

        const diffs: Array<Record<string, unknown>> = [];
        let added = 0;
        let removed = 0;
        let changed = 0;
        let unchanged = 0;

        for (let index = 0; index < maxLength; index++) {
          const leftLine = leftLines[index];
          const rightLine = rightLines[index];
          const lineNumber = index + 1;

          if (leftLine === undefined) {
            added++;
            diffs.push({
              type: "added",
              line: lineNumber,
              right: rightLine
            });
            continue;
          }

          if (rightLine === undefined) {
            removed++;
            diffs.push({
              type: "removed",
              line: lineNumber,
              left: leftLine
            });
            continue;
          }

          if (leftLine === rightLine) {
            unchanged++;
            diffs.push({
              type: "equal",
              line: lineNumber,
              text: leftLine
            });
            continue;
          }

          changed++;
          diffs.push({
            type: "changed",
            line: lineNumber,
            left: leftLine,
            right: rightLine
          });
        }

        output.value = JSON.stringify(
          {
            equal: added === 0 && removed === 0 && changed === 0,
            summary: {
              leftLines: leftLines.length,
              rightLines: rightLines.length,
              unchanged,
              changed,
              added,
              removed
            },
            diffs
          },
          null,
          2
        );

        return;
      }
            if (slug === "whois-lookup") {
        const value = input.value.trim();

        if (!value) {
          output.value = "Enter a domain name";
          return;
        }

        let domain = value
          .replace(/^https?:\/\//i, "")
          .replace(/^www\./i, "")
          .split("/")[0]
          .trim();

        if (!domain) {
          output.value = "Enter a valid domain name";
          return;
        }

        output.value = "Checking WHOIS...";

        fetch(`https://api.whois.vu/?q=${encodeURIComponent(domain)}`)
          .then((response: Response) => response.json())
          .then((data: any) => {
            if (!data || data.error) {
              output.value = "WHOIS lookup failed";
              return;
            }

            const result = {
              domain,
              registrar: data.registrar ?? null,
              created: data.created ?? null,
              expires: data.expires ?? null,
              updated: data.changed ?? data.updated ?? null,
              nameservers: data.nameservers ?? [],
              status: data.status ?? [],
              whoisServer: data.whoisserver ?? null
            };

            output.value = JSON.stringify(result, null, 2);
          })
          .catch(() => {
            output.value = "WHOIS lookup failed";
          });

        return;
      }

      if (slug === "txt-lookup") {
        const value = input.value.trim();

        if (!value) {
          output.value = "Enter a domain name";
          return;
        }

        let domain = value
          .replace(/^https?:\/\//i, "")
          .replace(/^www\./i, "")
          .split("/")[0]
          .trim();

        if (!domain) {
          output.value = "Enter a valid domain name";
          return;
        }

        output.value = "Checking TXT records...";

        fetch(`https://dns.google/resolve?name=${encodeURIComponent(domain)}&type=TXT`)
          .then((response: Response) => response.json())
          .then((data: any) => {
            const answers = Array.isArray(data.Answer)
              ? data.Answer.map((item: any) => item.data)
              : [];

            output.value =
              answers.length > 0
                ? answers.join("\n")
                : "No TXT records found";
          })
          .catch(() => {
            output.value = "TXT lookup failed";
          });

        return;
      }

      if (slug === "cname-lookup") {
        const value = input.value.trim();

        if (!value) {
          output.value = "Enter a domain or subdomain";
          return;
        }

        let domain = value
          .replace(/^https?:\/\//i, "")
          .replace(/^www\./i, "")
          .split("/")[0]
          .trim();

        if (!domain) {
          output.value = "Enter a valid domain or subdomain";
          return;
        }

        output.value = "Checking CNAME records...";

        fetch(`https://dns.google/resolve?name=${encodeURIComponent(domain)}&type=CNAME`)
          .then((response: Response) => response.json())
          .then((data: any) => {
            const answers = Array.isArray(data.Answer)
              ? data.Answer.map((item: any) => item.data)
              : [];

            output.value =
              answers.length > 0
                ? answers.join("\n")
                : "No CNAME records found";
          })
          .catch(() => {
            output.value = "CNAME lookup failed";
          });

        return;
      }

      output.value = "This tool logic is not connected yet.";
    });

    copyInputBtn?.addEventListener("click", async () => {
      if (!input) return;
      await navigator.clipboard.writeText(input.value);
    });

    clearBtn?.addEventListener("click", () => {
      if (!input || !output) return;
      input.value = "";
      output.value = "";
    });

    copyResultBtn?.addEventListener("click", async () => {
      if (!output) return;
      await navigator.clipboard.writeText(output.value);
    });

    downloadBtn?.addEventListener("click", () => {
      if (!output || !output.value) return;

      const blob = new Blob([output.value], { type: "text/plain;charset=utf-8" });
      const url = URL.createObjectURL(blob);
      const link = document.createElement("a");
      link.href = url;
      link.download = `${window.location.pathname.split("/").pop() || "tool-output"}.txt`;
      document.body.appendChild(link);
      link.click();
      link.remove();
      URL.revokeObjectURL(url);
    });
  });
