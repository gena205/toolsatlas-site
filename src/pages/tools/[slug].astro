if (slug === "mx-record-lookup") {
  const domain = input.value.trim().toLowerCase();

  if (!domain) {
    output.value = "Enter a domain like: gmail.com";
    return;
  }

  output.value = "Looking up MX records...";

  fetch(`https://dns.google/resolve?name=${encodeURIComponent(domain)}&type=MX`)
    .then((response: Response) => response.json())
    .then((data: {
      Status?: number;
      Answer?: Array<{ data?: string }>;
      Comment?: string;
    }) => {
      if (!Array.isArray(data.Answer) || data.Answer.length === 0) {
        output.value = "No MX records found.";
        return;
      }

      const result = data.Answer
        .map((item: { data?: string }) => item.data || "")
        .filter((value: string) => value.length > 0)
        .join("\n");

      output.value = result || "No MX records found.";
    })
    .catch(() => {
      output.value = "Unable to look up MX records.";
    });

  return;
}

