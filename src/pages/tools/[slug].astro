if (slug === "grade-calculator") {
  const lines = input.value
    .split(/\r?\n/)
    .map((line: string) => line.trim())
    .filter((line: string) => line.length > 0);

  if (!lines.length) {
    output.value = "Enter one item per line as: score weight\nExample:\n90 20\n80 30\n85 50";
    return;
  }

  let weightedTotal = 0;
  let totalWeight = 0;

  for (const line of lines) {
    const parts = line.match(/-?\d+(?:[.,]\d+)?/g)?.map((v: string) => Number(v.replace(",", "."))) || [];
    const score = parts[0];
    const weight = parts[1];

    if (!Number.isFinite(score) || !Number.isFinite(weight) || weight < 0) {
      output.value = "Each line must contain score and weight.\nExample:\n90 20\n80 30";
      return;
    }

    weightedTotal += score * (weight / 100);
    totalWeight += weight;
  }

  if (Math.abs(totalWeight - 100) > 0.01) {
    output.value = `Weights must total 100. Current total: ${totalWeight.toFixed(2)}`;
    return;
  }

  const finalGrade = weightedTotal;

  let letter = "F";
  if (finalGrade >= 90) letter = "A";
  else if (finalGrade >= 80) letter = "B";
  else if (finalGrade >= 70) letter = "C";
  else if (finalGrade >= 60) letter = "D";

  output.value =
    `Final grade: ${finalGrade.toFixed(2)}%\n` +
    `Letter grade: ${letter}`;
  return;
