        if (value && !/^\s/.test(value) && value.length > 0) {
          errors.push(`Line ${lineNumber}: Add a space after the colon.`);
        }
      }
    }

    previousIndent = indent;
    previousMeaningfulLine = content;
  });

  output.value =
    errors.length > 0
      ? `Invalid YAML.\n\n${errors.join("\n")}`
