          output.value = JSON.stringify(
            {
              pattern,
              flags: effectiveFlags,
              count: matches.length,
              matches
            },
            null,
            2
          );
        } catch {
          output.value = "Invalid regex pattern or flags.";
        }

        return;
      }

      if (slug === "lorem-ipsum-generator") {
        const text = input.value.trim();

        const config: Record<string, string> = {
