      .replace(/'/g, "&apos;");

  const buildXml = (key: string, value: unknown, indent = 0): string => {
    const space = "  ".repeat(indent);

    if (Array.isArray(value)) {
      return value.map((item: unknown) => buildXml(key, item, indent)).join("\n");
    }

    if (value === null || value === undefined) {
      return `${space}<${key}></${key}>`;
    }

    if (typeof value !== "object") {
      return `${space}<${key}>${escapeXml(String(value))}</${key}>`;
    }

    const obj = value as Record<string, unknown>;

    const attributes =
      obj["@attributes"] &&
      typeof obj["@attributes"] === "object" &&
      !Array.isArray(obj["@attributes"])
        ? (obj["@attributes"] as Record<string, unknown>)
        : {};

    const textValue =
      typeof obj["#text"] === "string" ||
      typeof obj["#text"] === "number" ||
      typeof obj["#text"] === "boolean"
        ? String(obj["#text"])
        : "";

    const children = Object.entries(obj).filter(
      ([childKey]) => childKey !== "@attributes" && childKey !== "#text"
    );

    const attrs = Object.entries(attributes)
      .map(([attrKey, attrValue]) => ` ${attrKey}="${escapeXml(String(attrValue))}"`)
      .join("");

    if (children.length === 0 && !textValue) {
      return `${space}<${key}${attrs}></${key}>`;
    }

    if (children.length === 0) {
      return `${space}<${key}${attrs}>${escapeXml(textValue)}</${key}>`;
    }

    const innerParts: string[] = [];

    if (textValue) {
      innerParts.push(`${"  ".repeat(indent + 1)}${escapeXml(textValue)}`);
    }

    innerParts.push(
      ...children.map(([childKey, childValue]) => buildXml(childKey, childValue, indent + 1))
    );

    return `${space}<${key}${attrs}>\n${innerParts.join("\n")}\n${space}</${key}>`;
  };

  try {
    const data = JSON.parse(text);

    let xmlBody = "";

