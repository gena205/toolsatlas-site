if (slug === "csv-column-extractor") {
  const raw = input.value.trim();

  if (!raw) {
    output.value = "Enter column name or 1-based column number on the first line, then a blank line, then the CSV data.";
    return;
  }

  const parts = raw.split(/\r?\n\r?\n/);
  const selector = (parts[0] || "").trim();
  const body = parts.slice(1).join("\n\n").trim();

  if (!selector || !body) {
    output.value = "Enter column name or 1-based column number on the first line, then a blank line, then the CSV data.";
    return;
  }

  const parseCsvLine = (line: string): string[] => {
    const result: string[] = [];
    let current = "";
    let inQuotes = false;

    for (let i = 0; i < line.length; i++) {
      const char = line[i];
      const next = line[i + 1];

      if (char === '"' && inQuotes && next === '"') {
        current += '"';
        i++;
      } else if (char === '"') {
        inQuotes = !inQuotes;
      } else if (char === "," && !inQuotes) {
        result.push(current);
        current = "";
      } else {
        current += char;
      }
    }

    result.push(current);
    return result;
  };

  const lines = body.split(/\r?\n/).filter((line: string) => line.trim().length > 0);

  if (lines.length < 2) {
    output.value = "CSV must include a header row and at least one data row.";
    return;
  }

  const headers = parseCsvLine(lines[0]).map((value: string) => value.trim());

  let columnIndex = -1;

  if (/^\d+$/.test(selector)) {
    columnIndex = Number(selector) - 1;
  } else {
    columnIndex = headers.findIndex((header: string) => header === selector);
  }

  if (columnIndex < 0 || columnIndex >= headers.length) {
    output.value = "Column not found.";
    return;
  }

  const values = lines.slice(1).map((line: string) => {
    const row = parseCsvLine(line);
    return row[columnIndex] ?? "";
  });

  output.value = values.join("\n");
  return;
}

