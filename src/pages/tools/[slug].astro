          count: "1",
          startWithLorem: "true"
        };

        if (text) {
          try {
            const parsed = JSON.parse(text);

            if (typeof parsed === "object" && parsed !== null && !Array.isArray(parsed)) {
              Object.entries(parsed as Record<string, unknown>).forEach(([key, value]) => {
                config[key] = String(value);
              });
            } else {
              output.value = "JSON input must be an object.";
              return;
            }
          } catch {
            const lines = text
              .split(/\r?\n/)
              .map((line: string) => line.trim())
              .filter((line: string) => line.length > 0);

            for (const line of lines) {
              const separatorIndex = line.indexOf("=");

              if (separatorIndex === -1) {
                output.value = `Invalid line: ${line}`;
                return;
              }

              const key = line.slice(0, separatorIndex).trim();
              const value = line.slice(separatorIndex + 1).trim();

              config[key] = value;
            }
          }
        }

        const unit = (config.unit || "paragraphs").trim().toLowerCase();
        const count = Math.max(1, Math.min(100, Number.parseInt(config.count || "1", 10) || 1));
        const startWithLorem = /^(true|1|yes|on)$/i.test(config.startWithLorem ?? "true");

        const loremWords = [
          "lorem", "ipsum", "dolor", "sit", "amet", "consectetur", "adipiscing", "elit",
          "sed", "do", "eiusmod", "tempor", "incididunt", "ut", "labore", "et", "dolore",
          "magna", "aliqua", "ut", "enim", "ad", "minim", "veniam", "quis", "nostrud",
          "exercitation", "ullamco", "laboris", "nisi", "ut", "aliquip", "ex", "ea",
          "commodo", "consequat"
        ];

        const loremSentences = [
          "Lorem ipsum dolor sit amet, consectetur adipiscing elit.",
          "Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.",
          "Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat.",
          "Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur.",
          "Excepteur sint occaecat cupidatat non proident, sunt in culpa qui officia deserunt mollit anim id est laborum."
        ];

        const wordOffset = startWithLorem ? 0 : 2;
        const sentenceOffset = startWithLorem ? 0 : 1;

        const generateWords = (wordCount: number): string => {
          const words = Array.from({ length: wordCount }, (_, index: number) => {
            return loremWords[(index + wordOffset) % loremWords.length];
          });

          const result = words.join(" ");
          return result.charAt(0).toUpperCase() + result.slice(1);
        };

        const generateSentences = (sentenceCount: number): string => {
          return Array.from({ length: sentenceCount }, (_, index: number) => {
            return loremSentences[(index + sentenceOffset) % loremSentences.length];
          }).join(" ");
        };

        const generateParagraphs = (paragraphCount: number): string => {
          return Array.from({ length: paragraphCount }, (_, paragraphIndex: number) => {
            const base = (paragraphIndex * 3 + sentenceOffset) % loremSentences.length;

            return [
              loremSentences[base % loremSentences.length],
              loremSentences[(base + 1) % loremSentences.length],
              loremSentences[(base + 2) % loremSentences.length]
            ].join(" ");
          }).join("\n\n");
        };

        if (unit === "word" || unit === "words") {
          output.value = generateWords(count);
          return;
        }

        if (unit === "sentence" || unit === "sentences") {
          output.value = generateSentences(count);
          return;
        }

        if (unit === "paragraph" || unit === "paragraphs") {
