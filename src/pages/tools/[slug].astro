---
import ToolLayout from "../../layouts/ToolLayout.astro";
import tools from "../../data/tools.json";

type ToolFaqItem = {
  q: string;
  a: string;
};

type ToolItem = {
  id: string;
  name: string;
  slug: string;
  category: string;
  intro: string;
  description: string;
  keywords?: string[];
  faq?: ToolFaqItem[];
  related?: string[];
};

const allTools = tools as ToolItem[];

export async function getStaticPaths() {
  return (tools as ToolItem[]).map((tool) => ({
    params: { slug: tool.slug },
    props: { tool }
  }));
}

const { tool } = Astro.props as { tool: ToolItem };
const relatedTools = allTools.filter((item) => tool.related?.includes(item.id));

function formatCategoryLabel(category: string): string {
  return category
    .split("-")
    .map((part: string) => part.charAt(0).toUpperCase() + part.slice(1))
    .join(" ");
}
---

<ToolLayout title={`${tool.name} Online Free Tool – Fast & Easy | ToolsAtlas`} description={`${tool.description} Free online tool. No installation required. Fast and easy to use.`}>
  <section class="card tool-hero">
    <p class="category-pill">{formatCategoryLabel(tool.category)}</p>
    <h1>{tool.name}</h1>
    <p class="lead">{tool.intro}</p>
  </section>

  <section class="card tool-panel">
    <div class="tool-panel-header">
      <div>
        <h2>Tool</h2>
        <p class="panel-text">{tool.description}</p>
      </div>
    </div>

    <div class="tool-grid">
      <div class="tool-column">
        <label for="tool-input" class="field-label">
          {tool.slug === "my-ip-address" ? "Info" : "Input"}
        </label>

        <textarea
          id="tool-input"
          class="tool-textarea"
          rows="12"
          placeholder={tool.slug === "my-ip-address"
            ? ""
            : `Paste or type your input for ${tool.name} here...`}
          style={tool.slug === "my-ip-address" ? "display:none;" : ""}
        ></textarea>

        {tool.slug === "my-ip-address" && (
          <div
            class="tool-textarea output-textarea"
            style="display:flex;align-items:center;justify-content:center;"
          >
            No input required for this tool.
          </div>
        )}

        {tool.slug !== "my-ip-address" && (
          <div class="button-row">
            <button type="button" class="primary-button">Run Tool</button>
            <button type="button" class="secondary-button">Copy Input</button>
            <button type="button" class="secondary-button">Clear</button>
          </div>
        )}
      </div>

      <div class="tool-column">
        <label for="tool-output" class="field-label">Output</label>
        <textarea
          id="tool-output"
          class="tool-textarea output-textarea"
          rows="12"
          placeholder="The result will appear here..."
          readonly
        ></textarea>

        <div class="button-row">
          <button type="button" class="secondary-button">Copy Result</button>
          <button type="button" class="secondary-button">Download</button>
        </div>
      </div>
    </div>
  </section>

    <section class="card">
    <h2>About this tool</h2>
    <p>{tool.description}</p>
    <p>
      This {tool.name.toLowerCase()} helps you complete common tasks quickly in the browser without installing anything.
    </p>
  </section>


  <section class="card">
  <h2>Why use this tool</h2>
  <ul>
    <li>Fast and simple to use directly in your browser</li>
    <li>No installation or signup required</li>
    <li>Works instantly on any device</li>
  </ul>
</section>

  <section class="card">
    <h2>How to use</h2>
    <ul class="steps-list">
      <li>Paste your text, value, or raw input into the input box.</li>
      <li>Run the tool to process the input.</li>
      <li>Review the output and copy the result if needed.</li>
    </ul>
  </section>

  <section class="card">
  <h2>About this tool</h2>
  <p>{tool.description}</p>
  <p>
    This {tool.name.toLowerCase()} helps you complete common tasks quickly in the browser without installing anything.
  </p>
</section>

  <section class="card">
    <h2>FAQ</h2>
    {tool.faq?.map((item) => (
      <div class="faq-item">
        <h3>{item.q}</h3>
        <p>{item.a}</p>
      </div>
    ))}
  </section>

  <section class="card">
  <h2>Use cases</h2>
  <ul>
    <li>Developers working with data and APIs</li>
    <li>Students and learners</li>
    <li>Quick everyday text or data tasks</li>
  </ul>
</section>

  <section class="card">
    <h2>Related tools</h2>
    <ul class="related-list">
      {relatedTools.map((item) => (
        <li>
          <a href={`/tools/${item.slug}`}>{item.name}</a>
        </li>
      ))}
    </ul>
  </section>
</ToolLayout>

<style>
  .tool-hero h1 {
    margin-bottom: 12px;
  }

  .category-pill {
    display: inline-flex;
    align-items: center;
    padding: 6px 12px;
    border-radius: 999px;
    background: rgba(110, 168, 254, 0.14);
    color: var(--accent);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 14px;
  }

  .lead {
    color: var(--muted);
    font-size: 18px;
    max-width: 760px;
    margin-bottom: 0;
  }

  .tool-panel {
    padding: 24px;
  }

  .tool-panel-header {
    margin-bottom: 18px;
  }

  .panel-text {
    color: var(--muted);
    margin-bottom: 0;
  }

  .tool-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 20px;
  }

  .tool-column {
    display: flex;
    flex-direction: column;
  }

  .field-label {
    display: inline-block;
    margin-bottom: 10px;
    font-size: 14px;
    font-weight: 700;
    color: var(--text);
  }

  .tool-textarea {
    width: 100%;
    min-height: 280px;
    resize: vertical;
    padding: 16px;
    border-radius: 14px;
    border: 1px solid var(--border);
    background: #0f172a;
    color: var(--text);
    font-size: 15px;
    line-height: 1.6;
    outline: none;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .tool-textarea:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(110, 168, 254, 0.14);
  }

  .output-textarea {
    background: #0d1528;
  }

  .button-row {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 14px;
  }

  .primary-button,
  .secondary-button {
    width: auto;
    min-width: 132px;
    padding: 12px 16px;
    border-radius: 12px;
    font-size: 14px;
    font-weight: 700;
    cursor: pointer;
    transition: transform 0.15s ease, opacity 0.15s ease, border-color 0.15s ease;
  }

  .primary-button:hover,
  .secondary-button:hover {
    transform: translateY(-1px);
  }

  .primary-button {
    background: var(--accent);
    color: #081120;
    border: none;
  }

  .secondary-button {
    background: transparent;
    color: var(--text);
    border: 1px solid var(--border);
  }

  .steps-list li + li,
  .related-list li + li {
    margin-top: 10px;
  }

  .faq-item + .faq-item {
    margin-top: 22px;
    padding-top: 22px;
    border-top: 1px solid var(--border);
  }

  @media (max-width: 900px) {
    .tool-grid {
      grid-template-columns: 1fr;
    }

    .lead {
      font-size: 16px;
    }

    .tool-textarea {
      min-height: 220px;
    }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const input = document.getElementById("tool-input") as HTMLTextAreaElement;
    const output = document.getElementById("tool-output") as HTMLTextAreaElement | null;

    const runBtn = document.querySelector(".primary-button") as HTMLButtonElement | null;
    const secondaryButtons = document.querySelectorAll(".secondary-button");

    const copyInputBtn = secondaryButtons[0] as HTMLButtonElement | undefined;
    const clearBtn = secondaryButtons[1] as HTMLButtonElement | undefined;
    const copyResultBtn = secondaryButtons[2] as HTMLButtonElement | undefined;
    const downloadBtn = secondaryButtons[3] as HTMLButtonElement | undefined;

    const slug = window.location.pathname.split("/").pop();

if (slug === "my-ip-address") {
  if (!output) return;

  output.value = "Loading your public IP address...";

  fetch("https://api.ipify.org?format=json", { cache: "no-store" })
    .then((response: Response) => {
      if (!response.ok) {
        throw new Error("Failed to fetch IP");
      }
      return response.json();
    })
    .then((data: { ip?: string }) => {
      output.value = data.ip
        ? `Your public IP: ${data.ip}`
        : "Unable to detect your IP address.";
    })
    .catch((error: unknown) => {
      console.error("my-ip-address error:", error);
      output.value = "Unable to detect your IP address.";
    });

  return;
}

    runBtn?.addEventListener("click", () => {
  if (!output) return;
  if (slug !== "my-ip-address" && !input) return;

      if (slug === "json-formatter") {
        try {
          const parsed = JSON.parse(input.value);
          output.value = JSON.stringify(parsed, null, 2);
        } catch {
          output.value = "Invalid JSON";
        }
        return;
      }

      if (slug === "json-validator") {
        try {
          JSON.parse(input.value);
          output.value = "Valid JSON";
        } catch {
          output.value = "Invalid JSON";
        }
        return;
      }

      if (slug === "json-minifier") {
        try {
          const parsed = JSON.parse(input.value);
          output.value = JSON.stringify(parsed);
        } catch {
          output.value = "Invalid JSON";
        }
        return;
      }

      if (slug === "base64-encode") {
        try {
          output.value = btoa(unescape(encodeURIComponent(input.value)));
        } catch {
          output.value = "Unable to encode input";
        }
        return;
      }

      if (slug === "base64-decode") {
        try {
          output.value = decodeURIComponent(escape(atob(input.value)));
        } catch {
          output.value = "Invalid Base64 input";
        }
        return;
      }

      if (slug === "url-encode") {
        output.value = encodeURIComponent(input.value);
        return;
      }

      if (slug === "url-decode") {
        try {
          output.value = decodeURIComponent(input.value);
        } catch {
          output.value = "Invalid URL-encoded input";
        }
        return;
      }

      if (slug === "html-encode") {
        const temp = document.createElement("textarea");
        temp.textContent = input.value;
        output.value = temp.innerHTML;
        return;
      }

      if (slug === "html-decode") {
        const temp = document.createElement("textarea");
        temp.innerHTML = input.value;
        output.value = temp.value;
        return;
      }

      if (slug === "text-case-converter") {
        output.value = input.value.toUpperCase();
        return;
      }

      if (slug === "remove-extra-spaces") {
        output.value = input.value.replace(/\s+/g, " ").trim();
        return;
      }

      if (slug === "word-counter") {
        const trimmed = input.value.trim();
        const words = trimmed ? trimmed.split(/\s+/).length : 0;
        const characters = input.value.length;
        const charactersNoSpaces = input.value.replace(/\s/g, "").length;
        const lines = input.value ? input.value.split(/\r?\n/).length : 0;

        output.value =
          `Words: ${words}\n` +
          `Characters: ${characters}\n` +
          `Characters (no spaces): ${charactersNoSpaces}\n` +
          `Lines: ${lines}`;
        return;
      }

      if (slug === "character-counter") {
        const characters = input.value.length;
        const charactersNoSpaces = input.value.replace(/\s/g, "").length;

        output.value =
          `Characters: ${characters}\n` +
          `Characters (no spaces): ${charactersNoSpaces}`;
        return;
      }

      if (slug === "text-reverser") {
        output.value = input.value.split("").reverse().join("");
        return;
      }

      if (slug === "lowercase-converter") {
        output.value = input.value.toLowerCase();
        return;
      }

      if (slug === "uppercase-converter") {
        output.value = input.value.toUpperCase();
        return;
      }

      if (slug === "line-counter") {
        const lines = input.value ? input.value.split(/\r?\n/).length : 0;
        output.value = `Lines: ${lines}`;
        return;
      }

      if (slug === "duplicate-line-remover") {
        const lines = input.value.split(/\r?\n/);
        const uniqueLines = [...new Set(lines)];
        output.value = uniqueLines.join("\n");
        return;
      }

            if (slug === "text-trimmer") {
        output.value = input.value.trim();
        return;
      }

      if (slug === "slug-generator") {
        output.value = input.value
          .toLowerCase()
          .trim()
          .replace(/[^a-z0-9\s-]/g, "")
          .replace(/\s+/g, "-")
          .replace(/-+/g, "-");
        return;
      }

      if (slug === "random-string-generator") {
        const length = 16;
        const chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789";
        let result = "";

        for (let i = 0; i < length; i++) {
          result += chars.charAt(Math.floor(Math.random() * chars.length));
        }

        output.value = result;
        return;
      }

      if (slug === "title-case-converter") {
        output.value = input.value
          .toLowerCase()
          .split(" ")
          .map((word) => word ? word.charAt(0).toUpperCase() + word.slice(1) : "")
          .join(" ");
        return;
      }

      if (slug === "sentence-case-converter") {
        const text = input.value.trim().toLowerCase();
        output.value = text ? text.charAt(0).toUpperCase() + text.slice(1) : "";
        return;
      }

            if (slug === "comma-to-newline") {
        output.value = input.value
          .split(",")
          .map((item) => item.trim())
          .filter((item) => item.length > 0)
          .join("\n");
        return;
      }

      if (slug === "newline-to-comma") {
        output.value = input.value
          .split(/\r?\n/)
          .map((item) => item.trim())
          .filter((item) => item.length > 0)
          .join(", ");
        return;
      }

      if (slug === "text-sorter") {
        output.value = input.value
          .split(/\r?\n/)
          .map((item) => item.trim())
          .filter((item) => item.length > 0)
          .sort((a, b) => a.localeCompare(b))
          .join("\n");
        return;
      }

      if (slug === "unique-lines") {
        const lines = input.value
          .split(/\r?\n/)
          .map((item) => item.trim())
          .filter((item) => item.length > 0);

        output.value = [...new Set(lines)].join("\n");
        return;
      }

      if (slug === "empty-line-remover") {
        output.value = input.value
          .split(/\r?\n/)
          .filter((line) => line.trim().length > 0)
          .join("\n");
        return;
      }

            if (slug === "remove-duplicate-words") {
        const words = input.value.trim().split(/\s+/);
        const uniqueWords = [...new Set(words.filter((word) => word.length > 0))];
        output.value = uniqueWords.join(" ");
        return;
      }

      if (slug === "reverse-lines") {
        output.value = input.value.split(/\r?\n/).reverse().join("\n");
        return;
      }

      if (slug === "sort-lines-descending") {
        output.value = input.value
          .split(/\r?\n/)
          .map((item) => item.trim())
          .filter((item) => item.length > 0)
          .sort((a, b) => b.localeCompare(a))
          .join("\n");
        return;
      }

      if (slug === "line-number-adder") {
        output.value = input.value
          .split(/\r?\n/)
          .map((line, index) => `${index + 1}. ${line}`)
          .join("\n");
        return;
      }

      if (slug === "tabs-to-spaces") {
        output.value = input.value.replace(/\t/g, "    ");
        return;
      }

      if (slug === "jwt-decoder") {
        try {
          const parts = input.value.trim().split(".");
          if (parts.length < 2) {
            output.value = "Invalid JWT";
            return;
          }

          const decodeBase64Url = (value: string): string => {
            const base64 = value.replace(/-/g, "+").replace(/_/g, "/");
            const padded = base64 + "=".repeat((4 - (base64.length % 4)) % 4);
            return decodeURIComponent(escape(atob(padded)));
          };

          const header = JSON.parse(decodeBase64Url(parts[0]));
          const payload = JSON.parse(decodeBase64Url(parts[1]));

          output.value =
            `Header:\n${JSON.stringify(header, null, 2)}\n\n` +
            `Payload:\n${JSON.stringify(payload, null, 2)}`;
        } catch {
          output.value = "Invalid JWT";
        }
        return;
      }

      if (slug === "url-parser") {
        try {
          const url = new URL(input.value.trim());
          const params: Record<string, string> = {};
url.searchParams.forEach((value: string, key: string) => {
  params[key] = value;
});

          output.value = JSON.stringify(
            {
              href: url.href,
              protocol: url.protocol,
              hostname: url.hostname,
              port: url.port,
              pathname: url.pathname,
              search: url.search,
              hash: url.hash,
              searchParams: params
            },
            null,
            2
          );
        } catch {
          output.value = "Invalid URL";
        }
        return;
      }

      if (slug === "html-stripper") {
        const temp = document.createElement("div");
        temp.innerHTML = input.value;
        output.value = temp.textContent || temp.innerText || "";
        return;
      }

      if (slug === "bytes-to-kb-converter") {
        const value = Number(input.value.trim());
        output.value = Number.isFinite(value) ? String(value / 1024) : "Invalid number";
        return;
      }

      if (slug === "kb-to-mb-converter") {
        const value = Number(input.value.trim());
        output.value = Number.isFinite(value) ? String(value / 1024) : "Invalid number";
        return;
      }

      if (slug === "discount-calculator") {
        const parts = input.value
          .split(/[\n,]+/)
          .map((item) => item.trim())
          .filter((item) => item.length > 0);

        if (parts.length < 2) {
          output.value = "Enter price and discount percent on separate lines";
          return;
        }

        const price = Number(parts[0]);
        const discount = Number(parts[1]);

        if (!Number.isFinite(price) || !Number.isFinite(discount)) {
          output.value = "Invalid numbers";
          return;
        }

        const discountAmount = (price * discount) / 100;
        const finalPrice = price - discountAmount;

        output.value =
          `Original price: ${price}\n` +
          `Discount percent: ${discount}\n` +
          `Discount amount: ${discountAmount}\n` +
          `Final price: ${finalPrice}`;
        return;
      }

            if (slug === "base64-url-encode") {
        try {
          output.value = btoa(unescape(encodeURIComponent(input.value)))
            .replace(/\+/g, "-")
            .replace(/\//g, "_")
            .replace(/=+$/g, "");
        } catch {
          output.value = "Unable to encode input";
        }
        return;
      }

      if (slug === "base64-url-decode") {
        try {
          let value = input.value.trim()
            .replace(/-/g, "+")
            .replace(/_/g, "/");

          while (value.length % 4 !== 0) {
            value += "=";
          }

          output.value = decodeURIComponent(escape(atob(value)));
        } catch {
          output.value = "Invalid Base64 URL input";
        }
        return;
      }

      if (slug === "url-parameter-extractor") {
        try {
          const url = new URL(input.value.trim());
          const params: string[] = [];

          url.searchParams.forEach((value, key) => {
            params.push(`${key}: ${value}`);
          });

          output.value = params.length > 0 ? params.join("\n") : "No query parameters found";
        } catch {
          output.value = "Invalid URL";
        }
        return;
      }

      if (slug === "query-string-parser") {
        try {
          const raw = input.value.trim().replace(/^\?/, "");
          const searchParams = new URLSearchParams(raw);
          const params: string[] = [];

          searchParams.forEach((value, key) => {
            params.push(`${key}: ${value}`);
          });

          output.value = params.length > 0 ? params.join("\n") : "No query parameters found";
        } catch {
          output.value = "Invalid query string";
        }
        return;
      }

      if (slug === "html-entities-encoder") {
        const temp = document.createElement("textarea");
        temp.textContent = input.value;
        output.value = temp.innerHTML;
        return;
      }

      if (slug === "html-entities-decoder") {
        const temp = document.createElement("textarea");
        temp.innerHTML = input.value;
        output.value = temp.value;
        return;
      }

      if (slug === "rot13-encoder") {
        output.value = input.value.replace(/[a-zA-Z]/g, (char) => {
          const start = char <= "Z" ? 65 : 97;
          return String.fromCharCode(((char.charCodeAt(0) - start + 13) % 26) + start);
        });
        return;
      }

      if (slug === "text-to-binary") {
        output.value = input.value
          .split("")
          .map((char) => char.charCodeAt(0).toString(2).padStart(8, "0"))
          .join(" ");
        return;
      }

      if (slug === "binary-to-text") {
        try {
          const cleaned = input.value.trim();
          const parts = cleaned.split(/\s+/).filter((part) => part.length > 0);

          output.value = parts
            .map((part) => {
              if (!/^[01]{8}$/.test(part)) {
                throw new Error("Invalid binary");
              }
              return String.fromCharCode(parseInt(part, 2));
            })
            .join("");
        } catch {
          output.value = "Invalid binary input";
        }
        return;
      }

      if (slug === "text-to-hex") {
        output.value = input.value
          .split("")
          .map((char) => char.charCodeAt(0).toString(16).padStart(2, "0"))
          .join(" ");
        return;
      }

            if (slug === "ipv4-validator") {
        const value = input.value.trim();
        const ipv4Regex =
          /^(25[0-5]|2[0-4]\d|1\d\d|[1-9]?\d)\.(25[0-5]|2[0-4]\d|1\d\d|[1-9]?\d)\.(25[0-5]|2[0-4]\d|1\d\d|[1-9]?\d)\.(25[0-5]|2[0-4]\d|1\d\d|[1-9]?\d)$/;
        output.value = ipv4Regex.test(value) ? "Valid IPv4" : "Invalid IPv4";
        return;
      }

      if (slug === "ipv6-validator") {
        const value = input.value.trim();
        const ipv6Regex =
          /^(([0-9a-fA-F]{1,4}:){7}[0-9a-fA-F]{1,4}|::1|::|([0-9a-fA-F]{1,4}:){1,7}:|:([0-9a-fA-F]{1,4}:){1,7}|([0-9a-fA-F]{1,4}:){1,6}:[0-9a-fA-F]{1,4})$/;
        output.value = ipv6Regex.test(value) ? "Valid IPv6" : "Invalid IPv6";
        return;
      }

