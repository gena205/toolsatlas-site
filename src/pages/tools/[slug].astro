if (slug === "keyword-density-checker") {
  const raw = input.value.trim();

  if (!raw) {
    output.value = "Enter a keyword on the first line, then a blank line, then the text.\nOr paste only text to see top repeated words.";
    return;
  }

  const parts = raw.split(/\r?\n\r?\n/);
  const firstPart = parts[0]?.trim() || "";
  const textBody = parts.length > 1 ? parts.slice(1).join("\n\n").trim() : raw;

  const normalize = (value: string): string =>
    value
      .toLowerCase()
      .replace(/[^\p{L}\p{N}\s]+/gu, " ")
      .replace(/\s+/g, " ")
      .trim();

  const normalizedText = normalize(textBody);
  const words = normalizedText.match(/[\p{L}\p{N}']+/gu) || [];

  if (!words.length) {
    output.value = "No words found in the text.";
    return;
  }

  if (parts.length > 1 && firstPart) {
    const keyword = normalize(firstPart);

    if (!keyword) {
      output.value = "Invalid keyword.";
      return;
    }

    const escaped = keyword.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
    const regex = new RegExp(`(?<!\\S)${escaped}(?!\\S)`, "gu");
    const matches = normalizedText.match(regex) || [];
    const density = (matches.length / words.length) * 100;

    output.value =
      `Keyword: ${keyword}\n` +
      `Occurrences: ${matches.length}\n` +
      `Total words: ${words.length}\n` +
      `Density: ${density.toFixed(2)}%`;
    return;
  }

  const counts: Record<string, number> = {};

  for (const word of words) {
    if (word.length < 3) continue;
    counts[word] = (counts[word] || 0) + 1;
  }

  const result = Object.entries(counts)
    .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]))
    .slice(0, 10)
    .map(([word, count]) => `${word}: ${count} (${((count / words.length) * 100).toFixed(2)}%)`)
    .join("\n");

  output.value = result || "No repeated keywords found.";
  return;
}

