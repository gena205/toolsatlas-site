  const hasBalancedQuotes = (line: string, quoteChar: '"' | "'"): boolean => {
    let count = 0;
    let escaped = false;

    for (const char of line) {
      if (quoteChar === '"' && char === "\\" && !escaped) {
        escaped = true;
        continue;
      }

      if (char === quoteChar && !escaped) {
        count++;
      }

      escaped = false;
    }

    return count % 2 === 0;
  };

  const lines = text.split("\n");
  let previousIndent = 0;
  let previousMeaningfulLine = "";

  lines.forEach((rawLine: string, index: number) => {
    const lineNumber = index + 1;

    if (!rawLine.trim() || rawLine.trim().startsWith("#")) {
      return;
    }

    if (/\t/.test(rawLine)) {
      errors.push(`Line ${lineNumber}: Tabs are not allowed in YAML indentation.`);
    }

    const line = rawLine.replace(/\s+$/g, "");
    const indent = line.match(/^\s*/)?.[0].length || 0;
    const content = line.trim();

    if (indent % 2 !== 0) {
      errors.push(`Line ${lineNumber}: Indentation should use multiples of 2 spaces.`);
    }

    if (
      indent > previousIndent + 2 &&
      !previousMeaningfulLine.endsWith(":") &&
      !previousMeaningfulLine.startsWith("- ")
    ) {
      errors.push(`Line ${lineNumber}: Indentation jumps too deeply.`);
    }

    if (/^-\S/.test(content)) {
      errors.push(`Line ${lineNumber}: List items should use "- " with a space.`);
    }

    if (!hasBalancedQuotes(content, '"')) {
      errors.push(`Line ${lineNumber}: Unbalanced double quotes detected.`);
    }

    if (!hasBalancedQuotes(content, "'")) {
      errors.push(`Line ${lineNumber}: Unbalanced single quotes detected.`);
    }

    if (
      content.includes(":") &&
      !content.startsWith("- ") &&
      !/^["'].*["']$/.test(content)
