---
import ToolLayout from "../../../layouts/ToolLayout.astro";
import ToolClusterNav from "../../../components/ToolClusterNav.astro";
import {
  allTools,
  getSafeCommonErrors,
  getSafeHowToUse,
  getSafeUseCases,
  getSafeWhyUse,
  buildToolPageDescription,
  buildToolPageHeading,
  buildToolPageLead,
  buildToolPageTitle,
  formatCategoryLabel,
  type ToolItem
} from "../../../lib/tools";

export async function getStaticPaths() {
  return allTools.map((tool) => ({
    params: { slug: tool.slug },
    props: { tool }
  }));
}

const { tool } = Astro.props as { tool: ToolItem };

const pageTitle = buildToolPageTitle(tool, "guide");
const pageDescription = buildToolPageDescription(tool, "guide");
const pageHeading = buildToolPageHeading(tool, "guide");
const pageLead = buildToolPageLead(tool, "guide");

const whyUse = getSafeWhyUse(tool);
const howToUse = getSafeHowToUse(tool);
const useCases = getSafeUseCases(tool);
const commonErrors = getSafeCommonErrors(tool);

const mainToolUrl = `/tools/${tool.slug}/`;
---

<ToolLayout title={pageTitle} description={pageDescription}>
  <section class="card tool-hero">
    <p class="category-pill">{formatCategoryLabel(tool.category)}</p>
    <h1>{pageHeading}</h1>
    <p class="lead">{pageLead}</p>
  </section>

  <section class="card">
    <ToolClusterNav slug={tool.slug} current="guide" />

    <h2>What this guide covers</h2>
    <p>{tool.description}</p>
    <p>
      This guide explains when to use {tool.name}, how to get a cleaner result,
      and which mistakes to avoid before moving on to related tools or the main tool page.
    </p>
  </section>

  <section class="card">
    <h2>Why use {tool.name}</h2>
    <ul>
      {whyUse.map((item) => (
        <li>{item}</li>
      ))}
    </ul>
  </section>

  <section class="card">
    <h2>How to use {tool.name}</h2>
    <ol class="steps-list">
      {howToUse.map((item) => (
        <li>{item}</li>
      ))}
    </ol>
  </section>

  <section class="card">
    <h2>Best use cases</h2>
    <ul>
      {useCases.map((item) => (
        <li>{item}</li>
      ))}
    </ul>
  </section>

  <section class="card">
    <h2>Common mistakes</h2>
    <div class="errors-list">
      {commonErrors.map((item) => (
        <div class="error-item">
          <h3>{item.issue}</h3>
          <p><strong>Fix:</strong> {item.fix}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="card callout-card">
    <h2>Use the tool</h2>
    <p>
      Ready to run {tool.name}? Open the main tool page to enter your input,
      generate the result, and copy or download the output.
    </p>
    <p class="cta-row">
      <a href={mainToolUrl} class="primary-link">Open {tool.name}</a>
    </p>
  </section>
</ToolLayout>

<style>
  .tool-hero h1 {
    margin-bottom: 12px;
  }

  .category-pill {
    display: inline-flex;
    align-items: center;
    padding: 6px 12px;
    border-radius: 999px;
    background: rgba(110, 168, 254, 0.14);
    color: var(--accent);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 14px;
  }

  .lead {
    color: var(--muted);
    font-size: 18px;
    max-width: 760px;
    margin-bottom: 0;
  }

  .steps-list li + li {
    margin-top: 10px;
  }

  .errors-list {
    display: grid;
    gap: 14px;
  }

  .error-item {
    padding: 16px;
    border: 1px solid var(--border);
    border-radius: 14px;
    background: #0d1528;
  }

  .error-item h3 {
    margin-bottom: 10px;
  }

  .callout-card {
    background: linear-gradient(180deg, rgba(110, 168, 254, 0.08), rgba(13, 21, 40, 0.9));
  }

  .cta-row {
    margin-top: 16px;
    margin-bottom: 0;
  }

  .primary-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 12px 16px;
    border-radius: 12px;
    background: var(--accent);
    color: #081120;
    text-decoration: none;
    font-size: 14px;
    font-weight: 700;
    transition: transform 0.15s ease, opacity 0.15s ease;
  }

  .primary-link:hover {
    transform: translateY(-1px);
    opacity: 0.95;
  }

  @media (max-width: 900px) {
    .lead {
      font-size: 16px;
    }
  }
</style>