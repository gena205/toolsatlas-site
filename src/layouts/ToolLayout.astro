---
const { title = "ToolsAtlas", description = "Useful online tools" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <style>
      :root {
        --bg: #0b1020;
        --card: #121a2f;
        --text: #e8eefc;
        --muted: #a9b4d0;
        --accent: #6ea8fe;
        --border: #22304f;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family: Arial, sans-serif;
        background: var(--bg);
        color: var(--text);
        line-height: 1.6;
      }

      a {
        color: var(--accent);
        text-decoration: none;
      }

      .container {
        max-width: 960px;
        margin: 0 auto;
        padding: 24px;
      }

      header {
        margin-bottom: 32px;
      }

      .brand {
        font-size: 28px;
        font-weight: 700;
      }

      .subtitle {
        color: var(--muted);
        margin-top: 8px;
      }

      .card {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 20px;
        margin-bottom: 20px;
      }

      h1, h2, h3 {
        margin-top: 0;
      }

      .small {
        color: var(--muted);
        font-size: 14px;
      }

      footer {
        margin-top: 40px;
        color: var(--muted);
        font-size: 14px;
      }

      input, textarea, button {
        width: 100%;
        padding: 12px;
        border-radius: 10px;
        border: 1px solid var(--border);
        background: #0f172a;
        color: var(--text);
        margin-top: 10px;
      }

      button {
        cursor: pointer;
        background: var(--accent);
        color: #081120;
        font-weight: 700;
        border: none;
      }

      ul {
        padding-left: 20px;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <header>
        <div class="brand"><a href="/">ToolsAtlas</a></div>
        <div class="subtitle">Simple online tools for developers, networking, text and conversions.</div>
      </header>

      <slot />

      <footer>
        © 2026 ToolsAtlas
      </footer>
    </div>
  </body>
</html>